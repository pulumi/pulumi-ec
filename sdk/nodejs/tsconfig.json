{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "config/index.ts",
        "config/vars.ts",
        "deployment.ts",
        "deploymentElasticsearchKeystore.ts",
        "deploymentExtension.ts",
        "deploymentTrafficFilter.ts",
        "deploymentTrafficFilterAssociation.ts",
        "elasticsearchProject.ts",
        "getAwsPrivatelinkEndpoint.ts",
        "getAzurePrivatelinkEndpoint.ts",
        "getDeployment.ts",
        "getDeploymentTemplates.ts",
        "getDeployments.ts",
        "getGcpPrivateServiceConnectEndpoint.ts",
        "getStack.ts",
        "getTrafficFilter.ts",
        "index.ts",
        "observabilityProject.ts",
        "organization.ts",
        "provider.ts",
        "securityProject.ts",
        "serverlessTrafficFilter.ts",
        "snapshotRepository.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts"
    ]
}
